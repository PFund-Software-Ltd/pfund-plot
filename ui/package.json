{
	"name": "@pfund-plot/ui",
	"version": "0.0.1-dev.3",
	"license": "Apache-2.0",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"build:watch": "vite build --watch --mode development",
		"build:widgets": "node scripts/build-widgets.js",
		"build:widgets:watch": "WIDGET_TARGET=all node scripts/build-widgets.js --watch",
		"build:widget": "vite build --config vite.widget.config.ts",
		"// Usage: WIDGET_TARGET=candlestick pnpm build:widget:watch:single or pnpm build:widget:watch:single (watches first widget):": "",
		"build:widget:watch": "node scripts/build-widgets.js --watch",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run"
	},
	"dependencies": {
		"@anywidget/svelte": "^0.1.0",
		"@bokeh/bokehjs": "^3.8.2",
		"lightweight-charts": "^5.1.0",
		"plotly.js": "^3.4.0",
		"vega-lite": "^6.4.2"
	},
	"devDependencies": {
		"@anywidget/types": "^0.2.0",
		"@anywidget/vite": "^0.2.2",
		"@eslint/compat": "^2.0.2",
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.53.4",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.2.1",
		"@types/node": "^25.3.3",
		"@types/plotly.js": "^3.0.10",
		"@vitest/browser": "^4.0.18",
		"eslint": "^10.0.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.15.0",
		"glob": "^13.0.6",
		"globals": "^17.4.0",
		"playwright": "^1.58.2",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.53.7",
		"svelte-check": "^4.4.4",
		"tailwindcss": "^4.2.1",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.56.1",
		"vite": "^7.3.1",
		"vitest": "^4.0.18",
		"vitest-browser-svelte": "^2.0.2"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	}
}
